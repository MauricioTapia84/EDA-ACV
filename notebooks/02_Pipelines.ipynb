# ==========================================
# 1. IMPORTS Y CONFIGURACION
# ==========================================

import sys
sys.path.append('..')

import pandas as pd
import numpy as np
from sklearn.pipeline import Pipeline
from sklearn.compose import ColumnTransformer
from sklearn.impute import SimpleImputer
from sklearn.preprocessing import StandardScaler, OneHotEncoder
from sklearn import set_config

from src.transformers import (
    DropColumnsTransformer,
    UnknownToNaNTransformer,
    DropHighMissingTransformer,
    OutlierCapper,
    DropZeroVarianceTransformer,
    SmartImputerTransformer
)

set_config(display="diagram")

# ==========================================
# 2. CARGA DE DATOS
# ==========================================

df_raw = pd.read_csv('../data/raw/healthcare-dataset-stroke-data.csv')
print(f"Dataset cargado: {df_raw.shape[0]} filas, {df_raw.shape[1]} columnas")

# ==========================================
# 3. DEFINICION DE VARIABLES POR TIPO
# ==========================================

# Variables numericas (continuas)
variables_numericas = ['age', 'avg_glucose_level', 'bmi']

# Variables categoricas (para one-hot encoding)
variables_categoricas = [
    'gender', 
    'hypertension', 
    'heart_disease', 
    'ever_married', 
    'work_type', 
    'Residence_type', 
    'smoking_status'
]

# Variable objetivo (se excluye del preprocesamiento)
target = 'stroke'

print("\nVariables configuradas:")
print(f"   Numericas ({len(variables_numericas)}): {variables_numericas}")
print(f"   Categoricas ({len(variables_categoricas)}): {variables_categoricas}")
print(f"   Target: {target}")

# ==========================================
# 4. PIPELINE DE PREPROCESAMIENTO
# ==========================================

# 4.1 Pipeline para variables numericas
num_pipe = Pipeline([
    ('capper', OutlierCapper(apply_capping=True)),      # Limita outliers extremos
    ('zero_variance', DropZeroVarianceTransformer()),   # Elimina columnas sin varianza
    ('scaler', StandardScaler())                        # Estandarizacion (media=0, std=1)
])

# 4.2 Pipeline para variables categoricas
cat_pipe = Pipeline([
    ('onehot', OneHotEncoder(
        handle_unknown='ignore',      # Ignora categorias no vistas en entrenamiento
        sparse_output=False           # Devuelve array denso (no matriz dispersa)
    ))
])

# 4.3 ColumnTransformer (enrutador)
preprocesador = ColumnTransformer(
    transformers=[
        ('num', num_pipe, variables_numericas),
        ('cat', cat_pipe, variables_categoricas)
    ],
    remainder='drop'                   # Elimina columnas no especificadas
)

# ==========================================
# 5. PIPELINE COMPLETO DE ML
# ==========================================

pipeline_ml_completo = Pipeline([
    # Paso 1: Eliminar columnas que causan fuga de informacion
    ('drop_id', DropColumnsTransformer(columns_to_drop=['id'])),
    
    # Paso 2: Convertir 'Unknown' a NaN (estandarizacion de nulos)
    ('limpieza_unknowns', UnknownToNaNTransformer()),
    
    # Paso 3: Eliminar columnas con mas del 70% de valores nulos
    ('drop_high_nan', DropHighMissingTransformer(threshold=0.7)),
    
    # Paso 4: Imputacion inteligente de valores nulos
    #   - <10% nulos: imputacion simple (media/moda)
    #   - >10% nulos: imputacion compleja (modelo predictivo - pendiente)
    ('smart_imputer', SmartImputerTransformer(low_threshold=0.10)),
    
    # Paso 5: Preprocesamiento final (escalado + codificacion)
    ('preprocesamiento', preprocesador)
])

print("\nPipeline construido correctamente")
print(pipeline_ml_completo)

# ==========================================
# 6. EJECUCION DEL PIPELINE
# ==========================================

print("\n" + "="*50)
print("EJECUTANDO PIPELINE...")
print("="*50)

# Separamos X (features) e y (target)
X_raw = df_raw.drop(columns=[target])
y_raw = df_raw[target]

print(f"\nDimensiones originales X: {X_raw.shape}")
print(f"Dimensiones originales y: {y_raw.shape}")

# Aplicamos el pipeline
X_procesado = pipeline_ml_completo.fit_transform(X_raw)

print(f"\nDimensiones procesadas X: {X_procesado.shape}")
print(f"   (Se generaron {X_procesado.shape[1]} variables despues de one-hot encoding)")

# ==========================================
# 7. VERIFICACION DE RESULTADOS
# ==========================================

print(f"\nTipo de dato de salida: {type(X_procesado)}")
print(f"Rango de valores (min, max): ({X_procesado.min():.4f}, {X_procesado.max():.4f})")

print("\nPrimeras 3 filas de la matriz procesada:")
print(X_procesado[:3])

# ==========================================
# 8. OBTENER NOMBRES DE VARIABLES FINALES
# ==========================================

enrutador = pipeline_ml_completo.named_steps['preprocesamiento']
nombres_finales = enrutador.get_feature_names_out()

print(f"\n" + "="*50)
print(f"LISTA DE VARIABLES FINALES ({len(nombres_finales)} columnas)")
print("="*50)

for i, nombre in enumerate(nombres_finales):
    nombre_limpio = nombre.replace('num__', '').replace('cat__', '')
    print(f"{i+1:03d}. {nombre_limpio}")

# ==========================================
# 9. VALIDACION DE INTEGRIDAD
# ==========================================

print("\n" + "="*50)
print("VALIDACION DE INTEGRIDAD")
print("="*50)

# Verificar que no hay valores nulos despues del pipeline
nulos_totales = np.isnan(X_procesado).sum()
print(f"Valores nulos en X_procesado: {nulos_totales}")

# Verificar que no hay valores infinitos
infinitos_totales = np.isinf(X_procesado).sum()
print(f"Valores infinitos en X_procesado: {infinitos_totales}")

# Verificar distribucion de target
print(f"\nDistribucion de variable objetivo 'stroke':")
print(y_raw.value_counts(normalize=True).mul(100).round(2).to_string())
